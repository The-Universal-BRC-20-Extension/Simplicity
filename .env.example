# Simplicity Indexer Configuration Example
# Copy this file to .env and configure for your environment

# =============================================================================
# IMPORTANT USAGE NOTES
# =============================================================================
# - For Docker Compose, use the Docker-specific DATABASE_URL and REDIS_URL below.
# - For manual/local use, use the localhost versions.
# - NEVER use default passwords in production or on a public network.
# - Edit all credentials and secrets before deploying publicly.
# - All sensitive settings are loaded from this file by docker-compose.yml.


# =============================================================================
# BITCOIN NODE (Local or External API)
# =============================================================================
# Set BITCOIN_RPC_URL depending on how you run:
#
#   Docker (default compose, indexer in container):
#     http://host.docker.internal:8332   ← container reaches host via this name
#
#   Docker with override (indexer on host network: cp docker-compose.override.yml.example docker-compose.override.yml):
#     http://127.0.0.1:8332             ← indexer runs like a local process
#
#   Local / pipenv (no Docker):
#     http://localhost:8332   or   http://127.0.0.1:8332
#
#   External RPC (QuickNode, Alchemy, etc.):
#     https://your-endpoint.example.com   and use BITCOIN_RPC_API_KEY (see below)
#
# (docker-compose has extra_hosts so host.docker.internal works on Linux.)
# If "Connection refused": bitcoin.conf needs rpcbind=0.0.0.0 and rpcallowip=172.17.0.0/16 for Docker.
# If 403 Forbidden with Docker: use the override so indexer uses 127.0.0.1 (see README).
BITCOIN_RPC_URL=http://host.docker.internal:8332
# Use the same credentials as in bitcoin.conf. If you use rpcuser/rpcpassword there, set them here (not __cookie__).
# If you use default cookie auth (no rpcuser in config), use BITCOIN_RPC_COOKIE_FILE or user __cookie__ and password from .cookie file.
BITCOIN_RPC_USER=your_rpc_user
BITCOIN_RPC_PASSWORD=your_rpc_password
# Optional: path to Bitcoin Core .cookie file (overrides user/password when set; inside Docker you usually use user/password instead)
# BITCOIN_RPC_COOKIE_FILE=/path/to/.cookie
#
# --- External RPC providers (QuickNode, Alchemy) ---
# For providers that use API-key/token in a header instead of Basic auth, set:
#   BITCOIN_RPC_API_KEY=your_provider_token
#   BITCOIN_RPC_AUTH_HEADER=Bearer   (default; or x-token for QuickNode, api-key for api-key header)
# Leave BITCOIN_RPC_USER/PASSWORD empty or ignore; API key takes precedence.
# QuickNode: create endpoint, use token from URL or set BITCOIN_RPC_API_KEY=token and BITCOIN_RPC_AUTH_HEADER=x-token.
# Alchemy: set BITCOIN_RPC_URL to your Bitcoin endpoint URL and BITCOIN_RPC_API_KEY to your API key (Bearer).
# Maestro: uses a REST-style API, not standard JSON-RPC; not compatible with this indexer unless they offer a JSON-RPC endpoint.
# BITCOIN_RPC_API_KEY=
# BITCOIN_RPC_AUTH_HEADER=Bearer

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Docker: the postgres container creates/uses the user from POSTGRES_USER and POSTGRES_PASSWORD.
# Set these so that migrate/indexer/api connect with the same user (compose builds DATABASE_URL from them).
POSTGRES_DB=brc20_indexer
POSTGRES_USER=indexer
POSTGRES_PASSWORD=indexer_password
# Only when using docker-compose.override.yml: host ports for Postgres/Redis (default 5433, 6380).
# Uncomment and change if 5433 or 6380 are already in use on the host.
# POSTGRES_HOST_PORT=5434
# REDIS_HOST_PORT=6381
#
# Snapshot restore (use one; if both set, local file takes precedence when present).
# On first run, if the DB is empty, the restore service will load the snapshot. See docs/SNAPSHOT.md.
# Option 1: local file in backups/ (path inside container; ./backups is mounted at /backups)
# SNAPSHOT_FILE=/backups/brc20_indexer_20260203_block934868.sql.gz
# Option 2: public URL (e.g. GitHub Release asset)
# SNAPSHOT_URL=https://github.com/temp-simplicity/simplicity-pre-publish/releases/download/snapshot_20260203_934868/brc20_indexer_20260203_block934868.sql.gz

# Manual/local: DATABASE_URL used as-is (same user/password as above if you created DB the same way).
# In Docker this line is overridden for migrate/indexer/api (they use POSTGRES_* above).
DATABASE_URL=postgresql://indexer:indexer_password@localhost:5432/brc20_indexer

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# For Docker Compose, uncomment the following line:
# REDIS_URL=redis://redis:6379/0
# For manual/local use, use the following line:
REDIS_URL=redis://localhost:6379/0

CACHE_TTL=300
CACHE_ENABLED=true

# =============================================================================
# API CONFIGURATION
# =============================================================================
# For local development: use 127.0.0.1 (localhost only)
# For Docker deployment: use 0.0.0.0 (container accessible from host)
API_HOST=127.0.0.1
# Use 8081 if 8080 is often in use on the host (e.g. another app or race on startup)
API_PORT=8080

CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://localhost:8081"]
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# INDEXER CONFIGURATION
# =============================================================================
START_BLOCK_HEIGHT=895534
BATCH_SIZE=100
MAX_BLOCKS_PER_BATCH=1000
CONTINUOUS_MODE=true
INDEXER_ONLY=false

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/indexer.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5
LOG_FORMAT=json

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
HEALTH_CHECK_INTERVAL=30
ENABLE_METRICS=true
METRICS_PORT=9090

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
DEBUG=false
RELOAD=false
TEST_DATABASE_URL=postgresql://indexer:indexer_password@localhost:5432/test_brc20_indexer

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
API_KEY=your_api_key_here
JWT_SECRET=your_jwt_secret_here

# =============================================================================
# SECURITY WARNING
# =============================================================================
# If you expose any service to the internet, you MUST change all default passwords and users in this file.
# Never expose PostgreSQL or Redis directly to the internet.